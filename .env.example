# Primary OpenRouter API key used by the pipeline and launchd wrapper.
OPENROUTER_API_KEY=

# Backward-compatibility fallback only. Prefer OPENROUTER_API_KEY.
ANTHROPIC_API_KEY=

# WeChat Webhook URL (optional, for delivery)
WECHAT_WEBHOOK_URL=

# Feishu custom bot delivery (optional)
FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
FEISHU_TIMEOUT_SECONDS=10
FEISHU_RETRY_COUNT=2

# Keep this false by default. Set it to true manually only when you want a forced test delivery.
ALLOW_NEEDS_REVIEW_DELIVERY=false
