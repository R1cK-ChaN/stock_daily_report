      <key>Weekday</key>
      <integer>3</integer>
      <key>Hour</key>
      <integer>15</integer>
      <key>Minute</key>
      <integer>1</integer>
    </dict>
    <dict>
      <key>Weekday</key>
      <integer>4</integer>
      <key>Hour</key>
      <integer>15</integer>
      <key>Minute</key>
      <integer>1</integer>
